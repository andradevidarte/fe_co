<odoo>
    <data>
        <record id="view_l10n_co_edi_log_tree" model="ir.ui.view">
            <field name="name">l10n_co_edi.log.tree</field>
            <field name="model">l10n_co_edi.log</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="create_date"/>
                    <field name="company_id"/>
                    <field name="level"/>
                    <field name="message"/>
                    <field name="move_id"/>
                </tree>
            </field>
        </record>

        <record id="view_l10n_co_edi_log_form" model="ir.ui.view">
            <field name="name">l10n_co_edi.log.form</field>
            <field name="model">l10n_co_edi.log</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="company_id"/>
                            <field name="level"/>
                            <field name="message"/>
                            <field name="move_id"/>
                            <field name="payload"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_l10n_co_edi_log" model="ir.actions.act_window">
            <field name="name">Technical Log</field>
            <field name="res_model">l10n_co_edi.log</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
