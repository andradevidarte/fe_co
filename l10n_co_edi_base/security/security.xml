<odoo>
    <data>
        <record id="group_l10n_co_edi_manager" model="res.groups">
            <field name="name">Colombia EDI Manager</field>
            <field name="category_id" ref="base.module_category_accounting"/>
        </record>

        <record id="rule_edi_queue_multi_company" model="ir.rule">
            <field name="name">EDI Queue multi-company</field>
            <field name="model_id" ref="model_l10n_co_edi_queue"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_edi_log_multi_company" model="ir.rule">
            <field name="name">EDI Log multi-company</field>
            <field name="model_id" ref="model_l10n_co_edi_log"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
