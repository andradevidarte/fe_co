<odoo>
    <data>
        <record id="view_company_form_l10n_co_edi" model="ir.ui.view">
            <field name="name">res.company.form.l10n.co.edi</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='configuration']" position="inside">
                    <group string="DIAN EDI">
                        <field name="dian_edi_enabled"/>
                        <field name="dian_environment" attrs="{'invisible': [('dian_edi_enabled','=',False)]}"/>
                        <field name="dian_test_set_id" attrs="{'invisible': [('dian_environment','!=','habilitacion')]}"/>

                        <group string="Certificate" attrs="{'invisible': [('dian_edi_enabled','=',False)]}">
                            <field name="dian_cert_pfx" filename="dian_cert_pfx_filename"/>
                            <field name="dian_cert_pfx_filename" invisible="1"/>
                            <field name="dian_cert_password" password="True"/>
                        </group>

                        <group string="Contingency" attrs="{'invisible': [('dian_edi_enabled','=',False)]}">
                            <field name="dian_contingency_enabled" readonly="1"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
